        { signal: AbortSignal.timeout(8000) }
      );
      if (_r.ok) {
        const _d = await _r.json();
        const suhu = _d.current?.temperature_2m;
        const kode = _d.current?.weathercode;
        const cuacaTxt =
          kode <= 1  ? "☀️" :
          kode <= 3  ? "⛅" :
          kode <= 67 ? "🌧️" :
          "🌩️";
        cuaca19 = `ʙᴜʟᴜᴋᴜᴍʙᴀ ${suhu}°ᴄ ${cuacaTxt}`;

        const _toZone19 = (isoStr) => {
          if (!isoStr) return null;
          const parts = isoStr.split("T");
          return parts[1] ? parts[1].slice(0, 5) : null;
        };
        const _toMinutes19 = (isoStr) => {
          if (!isoStr) return 0;
          const parts = isoStr.split("T")[1]?.split(":");
          return parts ? parseInt(parts[0]) * 60 + parseInt(parts[1]) : 0;
        };

        const nowMinutes19   = _wita19.getUTCHours() * 60 + _wita19.getUTCMinutes();
        const todaySunrise   = _d.daily?.sunrise?.[0];
        const todaySunset    = _d.daily?.sunset?.[0];

        if (todaySunrise && todaySunset) {
          const sunriseMinutes19 = _toMinutes19(todaySunrise);
          const sunsetMinutes19  = _toMinutes19(todaySunset);

          if (nowMinutes19 < sunriseMinutes19) {
            sunrise19 = _toZone19(todaySunrise);
            sunset19  = _toZone19(todaySunset);
          } else if (nowMinutes19 < sunsetMinutes19) {
            const tomorrow19    = new Date(_wita19.getTime() + 24 * 60 * 60 * 1000);
            const tomorrowStr   = `${tomorrow19.getUTCFullYear()}-${_pad19(tomorrow19.getUTCMonth() + 1)}-${_pad19(tomorrow19.getUTCDate())}`;
