            );
            if (_r2.ok) {
              const _d2 = await _r2.json();
              sunrise19 = _toZone19(_d2.daily?.sunrise?.[0]) || _toZone19(todaySunrise);
            } else {
              sunrise19 = _toZone19(todaySunrise);
            }
            sunset19 = _toZone19(todaySunset);
          } else {
