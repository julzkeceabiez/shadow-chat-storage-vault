        const hariList4 = ["ᴍɪɴɢɢᴜ","sᴇɴɪɴ","sᴇʟᴀsᴀ","ʀᴀʙᴜ","ᴋᴀᴍɪs","ᴊᴜᴍᴀᴛ","sᴀʙᴛᴜ"];
